# Unblink V2 - Environment Variables
# Copy this file to .env and fill in your values

# Backend/API port (web-agent style)
VITE_SERVER_API_PORT=8080

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/unblink

# JWT
JWT_SECRET=your-secret-key-here

# Dashboard
DASHBOARD_URL=http://localhost:8080

# Chat Model (OpenAI-compatible)
CHAT_OPENAI_MODEL=gpt-4o
CHAT_OPENAI_BASE_URL=https://api.openai.com/v1
CHAT_OPENAI_API_KEY=sk-your-key-here

# Fast Model (defaults to chat model if not set)
FAST_OPENAI_MODEL=gpt-4o
FAST_OPENAI_BASE_URL=https://api.openai.com/v1
FAST_OPENAI_API_KEY=sk-your-key-here

# Vision Language Model
VLM_OPENAI_MODEL=gpt-4-vision-preview
VLM_OPENAI_BASE_URL=https://api.openai.com/v1
VLM_OPENAI_API_KEY=sk-your-key-here
VLM_TIMEOUT_SEC=120

# Frame Processing
CONTENT_TRIM_SAFETY_MARGIN=10
FRAME_INTERVAL_SECONDS=5.0
FRAME_BATCH_SIZE=3

# Bridge Settings
BRIDGE_IDLE_TIMEOUT_SEC=300
BRIDGE_MAX_RETRIES=3

# Indexing
ENABLE_INDEXING=true
ENABLE_RECORDING=true

# Configuration
CONFIG_DIR=

# Frontend
# Set to path of built frontend to serve it from the Go server
# Leave empty to not serve frontend (use separate frontend server)
DIST_PATH=./app/dist
